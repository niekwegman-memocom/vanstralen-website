{
  "name": "vanstralen-website",
  "version": "1.0.0",
  "description": "Modern website for VanStralen restaurant with Next.js and Payload CMS",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=\"${NODE_OPTIONS} --no-deprecation\" next dev",
    "build": "cross-env NODE_OPTIONS=\"${NODE_OPTIONS} --no-deprecation\" next build",
    "start": "cross-env NODE_OPTIONS=\"${NODE_OPTIONS} --no-deprecation\" next start",
    "payload": "cross-env NODE_OPTIONS=\"${NODE_OPTIONS} --no-deprecation\" payload",
    "generate:types": "payload generate:types",
    "generate:importmap": "payload generate:importmap"
  },
  "dependencies": {
    "@payloadcms/db-sqlite": "3.0.0",
    "@payloadcms/next": "3.0.0",
    "@payloadcms/richtext-lexical": "3.0.0",
    "cross-env": "7.0.3",
    "next": "15.2.4",
    "payload": "3.0.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "sharp": "0.33.5"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "@types/react": "19.0.6",
    "@types/react-dom": "19.0.2",
    "typescript": "5.7.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
